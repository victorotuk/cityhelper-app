{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Nava",
  "version": "0.2.0",
  "identifier": "com.navaapp",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Nava",
        "width": 1280,
        "height": 840,
        "minWidth": 320,
        "minHeight": 400,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDM2MzZCNjI2NjBDMTM3MUUKUldRZU44RmdKclkyTmhDT0RYZUdROHhjbitTanV1Q2ZGaVpPNXZZQkFDRmwzQjFYcVZSZEtwdXcK",
      "endpoints": [
        "https://github.com/victorotuk/cityhelper-app/releases/latest/download/latest.json"
      ],
      "dialog": true
    }
  }
}
